# Non-secret defaults for /etc/default/arr-transfer-arbiter.
# The SABnzbd API key is read at runtime from the root-readable SAB config; do
# not add the key or any other credential here.
ARR_TRANSFER_SAB_URL=http://127.0.0.1:8085/api
ARR_TRANSFER_SAB_CONFIG=/srv/ssd1/docker/appdata/sabnzbd/sabnzbd.ini
ARR_TRANSFER_SAB_CONTAINER=sabnzbd
ARR_TRANSFER_QBIT_CONTAINER=qbittorrent
ARR_TRANSFER_QBIT_COMPOSE=/opt/arr-vpn/docker-compose.yml
ARR_TRANSFER_DOCKER=/usr/bin/docker
ARR_TRANSFER_POLL_SECONDS=2
ARR_TRANSFER_IDLE_GRACE_SECONDS=60
ARR_TRANSFER_BOOT_CHECK_SECONDS=60
ARR_TRANSFER_HTTP_TIMEOUT_SECONDS=5
ARR_TRANSFER_COMMAND_TIMEOUT_SECONDS=15
ARR_TRANSFER_VERIFY_TIMEOUT_SECONDS=15
