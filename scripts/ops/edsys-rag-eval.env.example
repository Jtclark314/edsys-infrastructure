# Install as /etc/edsys-secrets/edsys-rag-eval.env with mode 0600.
# Never commit the real value.  The scheduled deterministic acceptance gate
# requires only the Portal Basic Auth credential; cloud judge credentials stay
# absent. The installer rejects extra key names.
PORTAL_USERNAME=replace-with-private-portal-username
PORTAL_PASSWORD=replace-with-private-portal-password
