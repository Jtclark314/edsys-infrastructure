# Include this sanitized share definition from /etc/samba/smb.conf after
# creating the no-login courier-reader Unix/Samba identity.
[CourierMedia]
    path = /mnt/media/images
    browseable = no
    read only = yes
    guest ok = no
    valid users = courier-reader
    smb encrypt = required
    follow symlinks = no
    wide links = no
    veto files = /*.courier-part/
    hosts allow = 127.0.0.1 192.168.50.0/24 100.64.0.0/10
    hosts deny = 0.0.0.0/0
