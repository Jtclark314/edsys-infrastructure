MAILBRAIN_APP_NAME=MailBrain
MAILBRAIN_APP_ENV=production
MAILBRAIN_HOST=0.0.0.0
MAILBRAIN_PORT=8080
MAILBRAIN_PUBLIC_BASE_URL=https://mailbrain.edsyslab.com
MAILBRAIN_AUTH_ENABLED=true
MAILBRAIN_USERNAME=jeremy
MAILBRAIN_PASSWORD=change-me-in-private-env
MAILBRAIN_SQLITE_PATH=/data/mailbrain/mailbrain.sqlite
MAILBRAIN_STATE_DIR=/opt/edsys-workhorse/mailbrain
MAILBRAIN_ATTACHMENT_TEXT_EXTRACTION=true
MAILBRAIN_ATTACHMENT_BYTES_ARCHIVE=false
LITELLM_BASE_URL=http://192.168.50.50:4000/v1
LITELLM_API_KEY=replace-in-private-env
MAILBRAIN_SYNTHESIS_MODEL=edsys-chat-local
MAILBRAIN_ANSWER_MODEL=edsys-chat-local
MAILBRAIN_EMBEDDING_MODEL=edsys-embeddings-fast
MAILBRAIN_VECTOR_ENABLED=true
MAILBRAIN_QDRANT_URL=http://192.168.50.50:6333
MAILBRAIN_QDRANT_COLLECTION=mailbrain_email_chunks
MAILBRAIN_KNOWLEDGE_ROOT=/data/mailbrain/knowledge
MAILBRAIN_KNOWLEDGE_SQLITE_PATH=/data/mailbrain/knowledge/mailbrain_knowledge.sqlite
MAILBRAIN_KNOWLEDGE_QDRANT_COLLECTION=mailbrain_knowledge_chunks
MAILBRAIN_KNOWLEDGE_OBSIDIAN_VAULT_PATH=/mnt/ai-store/rag/docs/EdSysVault
MAILBRAIN_KNOWLEDGE_OBSIDIAN_NOTE_PATH=/mnt/ai-store/rag/docs/EdSysVault/70 AI & RAG/MailBrain Operator - RAG Summary.md
MAILBRAIN_KNOWLEDGE_GIT_PATHS=/host-code/edsys-mailbrain,/host-code/EdSys-Master
MAILBRAIN_KNOWLEDGE_GITHUB_REPOS=
MAILBRAIN_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
MAILBRAIN_GRAPH_MAILBOX=me
MAILBRAIN_INGEST_IGNORE_TERMS=
MAILBRAIN_INGEST_SUBJECT_HINT=Foothills -
GRAPH_ACCESS_TOKEN_FILE=/opt/edsys-workhorse/mailbrain/graph-access-token
