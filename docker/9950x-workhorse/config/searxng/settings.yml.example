# Template only. The prepare script writes the live file to /opt/edsys-workhorse/searxng/settings.yml.
use_default_settings: true
server:
  bind_address: "0.0.0.0"
  port: 8080
  secret_key: "replace-with-local-secret"
  base_url: "http://127.0.0.1:3017/"
redis:
  url: "redis://searxng-redis:6379/0"
search:
  safe_search: 1
  autocomplete: "duckduckgo"
