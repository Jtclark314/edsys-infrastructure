# 9950x workhorse stack example environment.
# Copy/generate a real .env outside Git with scripts/deploy/prepare-9950x-workhorse.sh.
# Never commit live values.

EDSYS_WORKHORSE_STATE_DIR=/opt/edsys-workhorse
WORKHORSE_LAN_BIND_IP=192.168.50.50
WORKHORSE_TAILSCALE_BIND_IP=100.87.137.47
DOZZLE_HOST_PORT=3013
NTFY_HOST_PORT=3015
NTFY_BASE_URL=http://192.168.50.50:3015
SEARXNG_HOST_PORT=3017
SEARXNG_BASE_URL=http://192.168.50.50:3017/
KARAKEEP_HOST_PORT=3018
KARAKEEP_VERSION=release
KARAKEEP_NEXTAUTH_URL=http://192.168.50.50:3018
KARAKEEP_DISABLE_SIGNUPS=false
KARAKEEP_NEXTAUTH_SECRET=replace-with-local-secret
KARAKEEP_MEILI_MASTER_KEY=replace-with-local-secret
HEALTHCHECKS_HOST_PORT=3014
HEALTHCHECKS_SITE_ROOT=http://192.168.50.50:3014
HEALTHCHECKS_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.50.50,100.87.137.47
HEALTHCHECKS_DB_NAME=healthchecks
HEALTHCHECKS_DB_USER=healthchecks
HEALTHCHECKS_DB_PASSWORD=replace-with-local-secret
HEALTHCHECKS_SECRET_KEY=replace-with-local-secret
BACKREST_HOST_PORT=9898
SCRUTINY_HOST_PORT=3016
SCRUTINY_COLLECTOR_PORT=8086
LOKI_HOST_PORT=3100
LITELLM_HOST_PORT=4000
LITELLM_DB_NAME=litellm
LITELLM_DB_USER=litellm
LITELLM_DB_PASSWORD=replace-with-local-secret
LITELLM_MASTER_KEY=sk-replace-with-local-secret
LITELLM_SALT_KEY=replace-with-local-secret
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=replace-with-local-secret
# LiteLLM client service keys are generated into /opt/edsys-workhorse/litellm/service-keys/ and are not part of this Compose .env.
LANGFUSE_HOST_PORT=3012
LANGFUSE_NEXTAUTH_URL=http://192.168.50.50:3012
LANGFUSE_POSTGRES_PASSWORD=replace-with-local-secret
LANGFUSE_CLICKHOUSE_PASSWORD=replace-with-local-secret
LANGFUSE_MINIO_ROOT_PASSWORD=replace-with-local-secret
LANGFUSE_REDIS_AUTH=replace-with-local-secret
LANGFUSE_SALT=replace-with-local-secret
LANGFUSE_ENCRYPTION_KEY=replace-with-64-hex-chars
LANGFUSE_NEXTAUTH_SECRET=replace-with-local-secret
LANGFUSE_TELEMETRY_ENABLED=false
LANGFUSE_INIT_ORG_ID=workhorse
LANGFUSE_INIT_ORG_NAME=EdSys Workhorse
LANGFUSE_INIT_PROJECT_ID=workhorse-ai-portal
LANGFUSE_INIT_PROJECT_NAME=EdSys Workhorse AI Portal
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=lf_pk_replace-with-local-secret
LANGFUSE_INIT_PROJECT_SECRET_KEY=lf_sk_replace-with-local-secret
LANGFUSE_INIT_USER_EMAIL=jeremy@edsys.local
LANGFUSE_INIT_USER_NAME=Jeremy
LANGFUSE_INIT_USER_PASSWORD=replace-with-local-secret
RENOVATE_TOKEN=
DOCKER_GROUP_GID=999
