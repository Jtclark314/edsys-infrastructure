APP_NAME=EdSys AI Portal
APP_ENV=production
PORTAL_HOST=0.0.0.0
PORTAL_PORT=8080

# 9950x LiteLLM workhorse binding. Real key is generated outside Git.
LITELLM_BASE_URL=http://192.168.50.50:4000/v1
LITELLM_API_KEY=sk-replace-me
LITELLM_TIMEOUT_SECONDS=120

DEFAULT_MODEL=edsys-chat-local
ALLOWED_MODELS=edsys-chat-local,edsys-chat-cloud,edsys-coder-local,edsys-coder-cloud,edsys-voice-fast,edsys-voice-quality
MODEL_CATALOG_PATH=/app/config/models.example.yaml
PROMPT_PRESETS_PATH=/app/config/prompts.example.json

# Phase 1 is stateless; history is deferred to Phase 1.5.
ENABLE_HISTORY=false
SQLITE_PATH=/data/edsys-ai-portal.sqlite

PORTAL_AUTH_ENABLED=true
PORTAL_USERNAME=jeremy
PORTAL_PASSWORD=CHANGE_ME

REQUIRE_CLOUD_CONFIRMATION=true
LOG_PROMPTS=false
LOG_RESPONSES=false
