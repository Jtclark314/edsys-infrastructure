APP_NAME=EdSys Workhorse AI Portal
APP_ENV=production
PORTAL_HOST=0.0.0.0
PORTAL_PORT=8080

# 9950x LiteLLM workhorse binding. Real key is generated outside Git.
LITELLM_BASE_URL=http://192.168.50.50:4000/v1
LITELLM_API_KEY=sk-replace-me
LITELLM_TIMEOUT_SECONDS=120

DEFAULT_MODEL=edsys-auto
ALLOWED_MODELS=edsys-auto,edsys-grounded-local,edsys-grounded-cloud,edsys-chat-local,edsys-chat-cloud,edsys-coder-local,edsys-coder-cloud,edsys-voice-fast,edsys-voice-quality
MODEL_CATALOG_PATH=/app/config/models.example.yaml
PROMPT_PRESETS_PATH=/app/config/prompts.example.json

# Phase 1 is stateless; history is deferred to Phase 1.5.
ENABLE_HISTORY=false
SQLITE_PATH=/data/edsys-ai-portal.sqlite

PORTAL_AUTH_ENABLED=true
PORTAL_USERNAME=jeremy
PORTAL_PASSWORD=CHANGE_ME

REQUIRE_CLOUD_CONFIRMATION=true

# Prompt-aware backend router. Keeps EdSys factual/admin prompts on current RAG,
# upgrades current-events/fresh-knowledge prompts to cloud chat after confirmation,
# and prefers coder aliases for coding prompts.
AUTO_ROUTE_MODELS=true
AUTO_ROUTE_AUTO_MODEL_ID=edsys-auto
AUTO_ROUTE_DEFAULT_MODEL=edsys-chat-local
AUTO_ROUTE_CURRENT_EVENTS_MODEL=edsys-chat-cloud
AUTO_ROUTE_EXTERNAL_KNOWLEDGE_MODEL=edsys-chat-cloud
AUTO_ROUTE_CODING_CLOUD_MODEL=edsys-coder-cloud
AUTO_ROUTE_CODING_LOCAL_MODEL=edsys-coder-local
AUTO_ROUTE_VOICE_FAST_MODEL=edsys-voice-fast
AUTO_ROUTE_UNWRAP_GROUNDED_FOR_NON_EDSYS=true

# Live web grounding for current/public questions. This is separate from
# EdSys RAG: current-events/external-knowledge prompts get private SearXNG
# search snippets injected before the LiteLLM call.
WEB_GROUNDING_ENABLED=true
WEB_GROUNDING_PROVIDER=searxng
WEB_GROUNDING_BASE_URL=http://192.168.50.50:3017
WEB_GROUNDING_TIMEOUT_SECONDS=12
WEB_GROUNDING_TOP_K=6
WEB_GROUNDING_MAX_CONTEXT_CHARS=10000
WEB_GROUNDING_REQUIRE_FOR_CURRENT_EVENTS=true
WEB_GROUNDING_REQUIRE_FOR_EXTERNAL_KNOWLEDGE=true
WEB_GROUNDING_BLOCK_ON_MISSING=true
WEB_GROUNDING_LANGUAGE=en

# Workhorse observability: Langfuse traces plus bounded/redacted Loki log lookups.
WORKHORSE_OBSERVABILITY_ENABLED=true
WORKHORSE_NAME=workhorse
LANGFUSE_ENABLED=true
LANGFUSE_BASE_URL=http://192.168.50.50:3012
LANGFUSE_PROJECT_ID=workhorse-ai-portal
LANGFUSE_PUBLIC_KEY=lf_pk_replace-with-backend-only-key
LANGFUSE_SECRET_KEY=lf_sk_replace-with-backend-only-key
LANGFUSE_TRACE_LOOKUP_LIMIT=50
LOKI_ENABLED=true
LOKI_BASE_URL=http://192.168.50.50:3100
LOKI_TIMEOUT_SECONDS=8
LOKI_DEFAULT_MINUTES=30
LOKI_DEFAULT_LIMIT=80
LOKI_ALLOWED_CONTAINERS=edsys-ai-portal,workhorse-litellm,workhorse-langfuse,workhorse-langfuse-worker,workhorse-loki,workhorse-alloy,workhorse-searxng

# Current-only EdSys RAG grounding. Real index is built outside Git.
RAG_ENABLED=true
RAG_REQUIRED_FOR_EDSYS_FACTS=true
RAG_BLOCK_ON_MISSING=true
RAG_INDEX_PATH=/data/rag/edsys-grounding.sqlite
RAG_FRESHNESS_SECONDS=900
RAG_TOP_K=6
RAG_MIN_RESULTS=1
RAG_MAX_CONTEXT_CHARS=14000

LOG_PROMPTS=false
LOG_RESPONSES=false
